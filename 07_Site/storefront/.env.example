# ─────────────────────────────────────────────────────────────
# ZAAYNAA — Variables d'environnement
# Copiez ce fichier en « .env » et remplissez les valeurs.
# Le fichier .env ne doit JAMAIS être commité (déjà dans .gitignore).
# ─────────────────────────────────────────────────────────────

# Secret de session (mettez n'importe quelle longue chaîne aléatoire)
SESSION_SECRET="changez-moi-par-une-longue-chaine-aleatoire"

# ─── Connexion Shopify réelle ───────────────────────────────
# Tant que ces variables sont VIDES, le site utilise les données
# de démonstration Mock.shop et fonctionne tout seul.
#
# Pour brancher la vraie boutique, le plus simple :
#   npx shopify hydrogen link        (relie le projet à votre boutique)
#   npx shopify hydrogen env pull    (récupère les clés automatiquement)
#
# Sinon, renseignez-les à la main depuis l'admin Shopify
# (Boutique > Paramètres > Apps et canaux > Hydrogen / Headless) :

# Domaine de la boutique, ex : zaaynaa.myshopify.com
PUBLIC_STORE_DOMAIN=""

# Jeton public d'accès à la Storefront API
PUBLIC_STOREFRONT_API_TOKEN=""

# Identifiant de la boutique (pour Shopify Analytics) — optionnel
PUBLIC_STOREFRONT_ID=""

# Domaine de checkout (par défaut = PUBLIC_STORE_DOMAIN)
PUBLIC_CHECKOUT_DOMAIN=""

# ─── Customer Accounts (connexion client) — optionnel ───────
PUBLIC_CUSTOMER_ACCOUNT_API_CLIENT_ID=""
PUBLIC_CUSTOMER_ACCOUNT_API_URL=""
